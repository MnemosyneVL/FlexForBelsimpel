# FlexForBelsimpel — Environment Configuration
#
# Copy this file to .env and adjust values for your environment.
# In Docker, most of these are already set correctly.

APP_NAME=FlexForBelsimpel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# --- DATABASE (MariaDB) ---
# MariaDB is our primary relational database.
# "mariadb" is the Docker service name — Docker DNS resolves it automatically.
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=flexforbelsimpel
DB_USERNAME=flex
DB_PASSWORD=secret

# --- CACHE (Redis) ---
# We use Redis for caching instead of file-based cache.
# Redis stores data in memory, making reads ~100x faster than disk.
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- SESSIONS (Redis) ---
# User sessions are also stored in Redis for speed.
# This means "who is logged in" checks don't hit the database.
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# --- QUEUE (RabbitMQ) ---
# Async jobs (search sync, notifications) go through RabbitMQ.
# The queue worker in the PHP container picks them up.
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=flex
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/

# --- ELASTICSEARCH ---
# Powers the phone/plan search with fuzzy matching and faceted filters.
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# --- MAIL (Mailpit) ---
# In development, emails go to Mailpit (a fake inbox).
# Visit http://localhost:8025 to see captured emails.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@flexforbelsimpel.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- LOGGING ---
LOG_CHANNEL=stack
LOG_LEVEL=debug
